# Container images
SERVER_IMAGE=ghcr.io/your-org-or-user/marketiq-server:latest
ML_IMAGE=ghcr.io/your-org-or-user/marketiq-ml:latest

# Database
POSTGRES_USER=marketiq
POSTGRES_PASSWORD=change-me
POSTGRES_DB=marketiq

# App secrets
DATABASE_URL=postgresql://marketiq:change-me@db:5432/marketiq
JWT_SECRET=change-me-long-random-string
JWT_REFRESH_SECRET=change-me-long-random-string
CLOUDINARY_URL=

# Mobile app runtime config
EXPO_PUBLIC_API_URL=https://api.example.com/api
EXPO_PUBLIC_ML_URL=https://ml.example.com